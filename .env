# =============================================
# Portfolio Email Server — SMTP Configuration
# =============================================
# STEP 1: Set your Gmail address below
GMAIL_USER=reemanhridoy@gmail.com

# STEP 2: Generate a Gmail App Password (NOT your regular Gmail password)
#   → Go to: https://myaccount.google.com/apppasswords
#   → Select "Mail" and "Windows Computer", then click Generate
#   → Paste the 16-character password below (no spaces)
GMAIL_PASS=your_app_password_here

# STEP 3: All contact form emails will be sent to this address
TO_EMAIL=reemanhridoy@gmail.com

# Server port (default 3000)
PORT=3000
